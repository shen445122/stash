name: Developer Sites Collapsed Tiles

desc: >-
  开发者站点折叠面板，适合直接作为日常开发环境检测 pack。
  聚合 GitHub、Stack Overflow、Vercel、Cloudflare、OpenAI、Anthropic，
  默认接入本仓库自托管 checker 脚本。

tiles:
  - name: GitHub-Check
    title: GitHub
    icon: https://cdn.simpleicons.org/github
    collapsed: true
    url: https://github.com

  - name: StackOverflow-Check
    title: Stack Overflow
    icon: https://cdn.simpleicons.org/stackoverflow
    collapsed: true
    url: https://stackoverflow.com

  - name: Vercel-Check
    title: Vercel
    icon: https://cdn.simpleicons.org/vercel
    collapsed: true
    url: https://vercel.com

  - name: Cloudflare-Check
    title: Cloudflare
    icon: https://cdn.simpleicons.org/cloudflare
    collapsed: true
    url: https://www.cloudflare.com

  - name: OpenAI-Check
    title: OpenAI
    icon: https://cdn.simpleicons.org/openai
    collapsed: true
    url: https://openai.com

  - name: Anthropic-Check
    title: Anthropic
    icon: https://cdn.simpleicons.org/anthropic
    collapsed: true
    url: https://www.anthropic.com

script-providers:
  GitHub-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/github.js

  StackOverflow-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/stackoverflow.js

  Vercel-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/vercel.js

  Cloudflare-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/cloudflare.js

  OpenAI-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/openai.js

  Anthropic-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/anthropic.js
