name: AI Tools Collapsed Tiles

desc: >-
  AI 工具折叠面板，适合直接作为常用 AI 服务检测 pack。
  聚合 ChatGPT、Claude、Gemini、Grok、Perplexity、GitHub Copilot，
  默认接入本仓库自托管 checker 脚本。

tiles:
  - name: ChatGPT-Web
    title: ChatGPT
    icon: https://fastly.jsdelivr.net/gh/StashNetworks/misc@main/collapsed-tiles/img/chatgpt.png
    collapsed: true
    url: https://chatgpt.com

  - name: Claude-Check
    title: Claude
    icon: https://cdn.simpleicons.org/anthropic
    collapsed: true
    url: https://claude.ai

  - name: Gemini-Check
    title: Gemini
    icon: https://cdn.simpleicons.org/googlegemini
    collapsed: true
    url: https://gemini.google.com

  - name: Grok-Check
    title: Grok
    icon: https://cdn.simpleicons.org/x
    collapsed: true
    url: https://grok.com

  - name: Perplexity-Check
    title: Perplexity
    icon: https://cdn.simpleicons.org/perplexity
    collapsed: true
    url: https://www.perplexity.ai

  - name: Copilot-Check
    title: GitHub Copilot
    icon: https://cdn.simpleicons.org/githubcopilot
    collapsed: true
    url: https://github.com/features/copilot

script-providers:
  ChatGPT-Web:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/chatgpt-web.js

  Claude-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/claude.js

  Gemini-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/gemini.js

  Grok-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/grok.js

  Perplexity-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/perplexity.js

  Copilot-Check:
    url: https://raw.githubusercontent.com/shen445122/stash/main/tiles/copilot.js
