# OpenClaw macOS bootstrap packages
# Intel and Apple Silicon both use this Brewfile; Homebrew resolves paths itself.

# Core CLI utilities
brew "jq"
brew "ripgrep"
brew "ffmpeg"

# Apple Notes CLI
brew "antoniorodr/memo/memo"

# UI automation / vision
brew "steipete/tap/peekaboo"

# Optional but commonly useful for OCR / image workflows
brew "imagemagick"
